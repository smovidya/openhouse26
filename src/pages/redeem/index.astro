---
import Layout from "@src/layouts/ContentLayout.astro";
import RedeemFlow from "@src/components/redeem/RedeemFlow.svelte";
import PageLayout from "@src/layouts/Pagelayout.astro";
import Card from "@src/components/card.svelte";

const ticketIdQuery = Astro.url.searchParams.get("ticketId") || "";
---

<Layout title="Redeem Certificate - Sci Chula Openhouse 2026">
  <PageLayout>
    <article class="flex -translate-y-17 flex-col gap-4 px-8">
      <Card>
        <span class="text-center text-xl font-bold">Redeem Certificate</span>
      </Card>
      <RedeemFlow client:load ticketId={ticketIdQuery} />
    </article>
  </PageLayout>
</Layout>

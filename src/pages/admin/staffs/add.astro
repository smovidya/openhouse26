---
import Layout from "@src/layouts/ManagementLayout.astro";
import AddStaffForm from "@src/components/admin/staff/add-staff-form.svelte";
import Breadcrumb from "@src/components/common/breadcrumb.svelte";
---

<Layout title="เพิ่มสตาฟคนใหม่">
  <Breadcrumb
    items={[
      { label: "แดชบอร์ดผู้ดูแลระบบ", href: "/admin" },
      { label: "รายชื่อผู้ใช้ทั้งหมด", href: "/admin/users" },
    ]}
  />
  <h1>เพิ่มสตาฟจากชีต</h1>
  <p>หน้านี้ใช้สำหรับเพิ่มสตาฟใหม่จากชีตที่เตรียมไว้</p>
  <AddStaffForm client:load />
</Layout>

import Breadcrumb from "@src/components/common/breadcrumb.svelte";
import CompetitorDatatable from "@src/components/admin/scilympic/competitor-datatable.svelte";
---

<Layout>
  <Breadcrumb
    items={[
      { label: "แดชบอร์ดผู้ดูแลระบบ", href: "/admin" },
      { label: "จัดการทีม Scilympic", href: "/admin/scilympic" },
    ]}
  />
  <h1>จัดการทีม Scilympic</h1>
  <p class="mb-4 text-sm opacity-70">
    หน้านี้สำหรับเพิ่ม แก้ไข และลบข้อมูลทีมแข่งขันแบบ soft delete
  </p>
  <CompetitorDatatable client:load />
</Layout>
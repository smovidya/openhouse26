---
import Layout from "@src/layouts/ContentLayout.astro";
import BioContainer from "@src/container/website/child.svelte";
import { websitesData } from "@src/data/website";
import PageLayout from "@src/layouts/Pagelayout.astro";
---

<Layout>
  <PageLayout>
    <BioContainer
      client:load
      data={websitesData.filter((item) => item.key === "bio")}
    />
  </PageLayout>
</Layout>

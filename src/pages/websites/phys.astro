---
import Layout from "@src/layouts/ContentLayout.astro";
import PhysContainer from "@src/components/website/child.svelte";
import { websitesData } from "@src/data/website";
import PageLayout from "@src/layouts/Pagelayout.astro";
---

<Layout>
  <PageLayout>
    <PhysContainer
      client:load
      data={websitesData.filter((item) => item.key === "phys")}
    />
  </PageLayout>
</Layout>

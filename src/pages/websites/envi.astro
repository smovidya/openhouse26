---
import Layout from "@src/layouts/ContentLayout.astro";
import EnviContainer from "@src/components/website/child.svelte";
import { websitesData } from "@src/data/website";
import PageLayout from "@src/layouts/Pagelayout.astro";
---

<Layout>
  <PageLayout>
    <EnviContainer
      client:load
      data={websitesData.filter((item) => item.key === "envi")}
    />
  </PageLayout>
</Layout>

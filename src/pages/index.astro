---
import Layout from "../layouts/ContentLayout.astro";
import { Image } from "astro:assets";

import LoginButton from "@src/components/login-button.svelte";
import Button from "@src/components/common/button.svelte";

import { featureFlags } from "@src/data/constants";
import { actions } from "astro:actions";

const user = Astro.locals.user;

const { data } = await Astro.callAction(actions.amIRegistered, {});
const isRegistered = data?.results ?? false;

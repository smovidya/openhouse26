    <div
      class="mt-10 flex max-w-xs flex-col items-center gap-2 rounded-lg bg-white/20 p-6 text-center backdrop-blur-sm"
    >
      <img class="max-auto mb-3 w-1/3" src="/landing/logo-white.png" />
      <b class="text-3xl">เดี๋ยวกลับมา!</b>
      <p class="text-balance">
        เว็บไซต์กำลังอยู่ระหว่างการปรับปรุงสำหรับงานวันที่ 28 - 29 มีนาคม
        แล้วกลับมาพบกันน้า ติดตามข่าวสารได้ที่ Instagram:{" "}<a
          href="https://www.instagram.com/sciencechulaopenhouse/"
          target="_blank"
          class="underline">@sciencechulaopenhouse</a
        >
      </p>
    </div>
  </div>

  <script>
    document.querySelectorAll("img[data-parallax-speed]").forEach((img) => {
      const speed = parseFloat(img.getAttribute("data-parallax-speed")!);
      window.addEventListener("scroll", () => {
        const offset = window.scrollY * speed;
        (img as HTMLElement).style.transform = `translateY(${offset}px)`;
      });
      ``;
    });
  </script>
</Layout>

---
import { cn } from "@src/components/utils";
import Base from "./Base.astro";
import NavBar from "@src/components/navbar.svelte";
import Footer from "@src/components/footer.svelte";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  showNavBar?: boolean;
  theme?: string;
  blueBg?: boolean;
}

const {
  title,
  description,
  image,
  showNavBar = false,
  theme,
  blueBg = true,
} = Astro.props;
---

<Base title={title} description={description} image={image} theme={theme}>
  <div
    class="MainContainer flex h-full w-full flex-col overflow-hidden shadow-xl"
  >
    <div class="shrink-0">
      <NavBar client:load />
    </div>
    <div class="flex grow flex-col overflow-x-hidden overflow-y-auto">
      <div class="grow">
        <div class="h-full w-full overflow-auto">
          <slot />
        </div>
      </div>
      <Footer />
    </div>
  </div>
</Base>

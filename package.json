{
  "name": "openhouse25",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "wrangler types && astro dev",
    "start": "wrangler types && astro dev",
    "build": "wrangler types && astro check && astro build",
    "check": "wrangler types && astro check",
    "preview": "wrangler types && astro preview",
    "deploy": "bun run build && bun x wrangler deploy --env=\"\"",
    "astro": "astro",
    "cf-types": "wrangler types",
    "db:generate": "bun drizzle-kit generate",
    "db:studio": "bun drizzle-kit studio",
    "d1:migrate": "bun wrangler d1 migrations apply openhouse26_2_db --local",
    "d1:migrate:remote": "bun wrangler d1 migrations apply openhouse26_2_db --remote",
    "d1:migrate:staging": "bun wrangler d1 migrations apply openhouse26_2_db --remote -e staging",
    "auth:generate": "bun x @better-auth/cli@latest generate --output ./src/db/schema/auth.schema.ts --config ./src/auth/index.ts -y",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/cloudflare": "13.1.3",
    "@astrojs/svelte": "8.0.3",
    "@bwip-js/browser": "^4.8.0",
    "@bwip-js/generic": "^4.8.0",
    "@bwip-js/node": "^4.8.0",
    "@libsql/client": "^0.17.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/svelte-form": "^1.28.5",
    "@types/bwip-js": "^3.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@zxing/library": "^0.21.3",
    "ag-grid-react": "^35.1.0",
    "arktype": "^2.2.0",
    "astro": "6.0.8",
    "better-auth": "^1.5.6",
    "better-auth-cloudflare": "^0.2.9",
    "bits-ui": "^2.16.3",
    "bwip-js": "^4.8.0",
    "carbon-icons-svelte": "^13.9.1",
    "clsx": "^2.1.1",
    "devalue": "^5.6.4",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "formsnap": "^2.0.1",
    "google-auth-library": "^10.6.2",
    "google-spreadsheet": "^5.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "qr-scanner": "^1.4.2",
    "runed": "^0.37.1",
    "svelte": "^5.54.1",
    "svelte-sonner": "^1.1.0",
    "sveltekit-superforms": "^2.30.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vaul-svelte": "0.3.2",
    "wrangler": "^4.77.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/puppeteer": "^1.0.6",
    "@tailwindcss/typography": "^0.5.19",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "svelte-hamburgers": "^5.0.0"
  },
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "@tailwindcss/oxide",
    "better-sqlite3",
    "esbuild",
    "prisma",
    "sharp",
    "workerd"
  ]
}